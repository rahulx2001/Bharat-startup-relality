# NVIDIA NIM (OpenAI-compatible) — https://build.nvidia.com/
# Never commit real keys. Copy to .env (gitignored).
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm-5.2

# Optional request tuning
# NVIDIA_MAX_TOKENS=8192

# Pipeline tuning
MAX_NEW_STARTUPS_PER_RUN=5
MAX_ARTICLES_PER_RUN=40

# Research quality gate (perfect-mode defaults)
RESEARCH_REQUIRE_GOLD_FOR_NEW=true
RESEARCH_REQUIRE_GOLD_FOR_UPDATE=false
RESEARCH_MAX_REPAIR_PASSES=2
